{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionReceipt",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "producer",
    "trace_id",
    "run_id",
    "content_hash",
    "created_at",
    "receipt_id",
    "input_hash",
    "output_hash",
    "active_mechanism_class_ids",
    "provisional_mechanism_class_ids",
    "policy_clauses_triggered",
    "geometry_anomaly_flags",
    "chart_instability_flags",
    "decision",
    "policy_version",
    "evaluated_claims",
    "thresholds_applied",
    "falsifiers_checked",
    "fallback_selected",
    "immutable_bundle_hash"
  ],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "decision_receipt" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "producer": { "type": "string", "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "trace_id": { "type": "string" },
    "run_id": { "type": "string" },
    "content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "receipt_id": { "type": "string" },
    "input_hash": { "type": "string" },
    "output_hash": { "type": "string" },
    "active_mechanism_class_ids": { "type": "array", "items": { "type": "string" } },
    "provisional_mechanism_class_ids": { "type": "array", "items": { "type": "string" } },
    "policy_clauses_triggered": { "type": "array", "items": { "type": "string" } },
    "geometry_anomaly_flags": { "type": "array", "items": { "type": "string" } },
    "chart_instability_flags": { "type": "array", "items": { "type": "string" } },
    "decision": { "type": "string" },
    "policy_version": { "type": ["string", "null"] },
    "evaluated_claims": { "type": ["array", "null"], "items": { "type": "string" } },
    "thresholds_applied": { "type": ["object", "null"] },
    "falsifiers_checked": { "type": ["array", "null"], "items": { "type": "string" } },
    "fallback_selected": { "type": ["string", "null"] },
    "immutable_bundle_hash": { "type": ["string", "null"] }
  }
}
