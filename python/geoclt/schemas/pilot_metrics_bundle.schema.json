{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PilotMetricsBundle",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "producer",
    "trace_id",
    "run_id",
    "content_hash",
    "created_at",
    "payload"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "pilot_metrics_bundle"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "producer": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "required": [
        "pilot_scope_ref",
        "window_id",
        "false_allow_rate",
        "false_block_rate",
        "routing_quality",
        "trust_metrics",
        "drift_summary"
      ],
      "properties": {
        "pilot_scope_ref": {
          "type": "string"
        },
        "window_id": {
          "type": "string"
        },
        "false_allow_rate": {
          "type": "number"
        },
        "false_block_rate": {
          "type": "number"
        },
        "routing_quality": {
          "type": "number"
        },
        "trust_metrics": {
          "type": "object"
        },
        "drift_summary": {
          "type": "object"
        }
      }
    }
  }
}
