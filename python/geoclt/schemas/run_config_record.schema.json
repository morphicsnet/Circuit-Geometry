{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunConfigRecord",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "producer",
    "trace_id",
    "run_id",
    "content_hash",
    "created_at",
    "payload"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "run_config_record"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "producer": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "required": [
        "lane_id",
        "model_profile_ref",
        "dataset_manifest_ref",
        "scorecard_ref",
        "runtime_flags",
        "fallback_config",
        "replay_mode",
        "seed_policy"
      ],
      "properties": {
        "lane_id": {
          "type": "string"
        },
        "model_profile_ref": {
          "type": "string"
        },
        "dataset_manifest_ref": {
          "type": "string"
        },
        "scorecard_ref": {
          "type": "string"
        },
        "runtime_flags": {
          "type": "object"
        },
        "fallback_config": {
          "type": "object"
        },
        "replay_mode": {
          "type": "string"
        },
        "seed_policy": {
          "type": "string"
        }
      }
    }
  }
}
