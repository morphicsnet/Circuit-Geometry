{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PilotScopePolicyRecord",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "producer",
    "trace_id",
    "run_id",
    "content_hash",
    "created_at",
    "payload"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "pilot_scope_policy_record"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "producer": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "required": [
        "policy_id",
        "policy_version",
        "identity_key_id",
        "in_scope_users",
        "in_scope_tasks",
        "allowed_corpora",
        "review_required_actions",
        "prohibited_actions"
      ],
      "properties": {
        "policy_id": {
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "identity_key_id": {
          "type": "string"
        },
        "in_scope_users": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "in_scope_tasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_corpora": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_required_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
