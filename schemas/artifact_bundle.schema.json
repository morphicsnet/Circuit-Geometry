{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtifactBundle",
  "type": "object",
  "required": ["bundle_id", "schema_version", "producer", "run_id", "trace_id", "created_at", "artifacts", "bundle_hash", "immutable"],
  "properties": {
    "bundle_id": {"type": "string"},
    "schema_version": {"type": "integer", "minimum": 1},
    "producer": {"type": "string", "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "run_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "transitional": {"type": "boolean", "default": false},
    "immutable": {"type": "boolean"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type", "schema_version", "producer", "trace_id", "run_id", "content_hash", "created_at", "payload"],
        "properties": {
          "artifact_id": {"type": "string"},
          "artifact_type": {"type": "string"},
          "schema_version": {"type": "integer", "minimum": 1},
          "producer": {"type": "string", "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "trace_id": {"type": "string"},
          "run_id": {"type": "string"},
          "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "created_at": {"type": "string", "format": "date-time"},
          "payload": {"type": "object"}
        }
      }
    },
    "bundle_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
