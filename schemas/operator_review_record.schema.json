{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperatorReviewRecord",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "producer",
    "trace_id",
    "run_id",
    "content_hash",
    "created_at",
    "payload"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "operator_review_record"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "producer": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "trace_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "required": [
        "review_record_id",
        "reviewer_pseudonym",
        "identity_key_id",
        "task_ref",
        "accepted",
        "override",
        "explanation_usefulness",
        "receipt_usefulness",
        "escalation_appropriateness",
        "confidence_calibration_agreement"
      ],
      "properties": {
        "review_record_id": {
          "type": "string"
        },
        "reviewer_pseudonym": {
          "type": "string"
        },
        "identity_key_id": {
          "type": "string"
        },
        "task_ref": {
          "type": "string"
        },
        "accepted": {
          "type": "boolean"
        },
        "override": {
          "type": "boolean"
        },
        "explanation_usefulness": {
          "type": "number"
        },
        "receipt_usefulness": {
          "type": "number"
        },
        "escalation_appropriateness": {
          "type": "number"
        },
        "confidence_calibration_agreement": {
          "type": "number"
        }
      }
    }
  }
}
